# Secrets - NEVER commit unencrypted secrets
**/secrets/*.yaml
!**/secrets/*.sealed.yaml
*.key
*.pem
*.crt

# Ansible
ansible/inventory/hosts.yml    # Contains real IPs -- use hosts.yml.example
*.retry

# Helm: Chart.lock + charts/*.tgz are committed so Argo CD can `helm template` without `helm dependency build`.

# Kubeconfig
kubeconfig
*.kubeconfig
k3s.yaml

# Environment files with secrets
.env
.env.*

# OS
.DS_Store
Thumbs.db

# IDE
.cursor/
.vscode/
.claude/
.idea/
*.swp
*.swo
*~

# Temp
*.tmp
*.bak
*.log

# My Files 
/docs/hand-holding-guide.md
